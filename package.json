{
  "name": "@sgnl-actions/ad-move-user",
  "description": "Move a user to a new parent container/OU in Active Directory",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "rollup -c && generate-license-file --input package.json --output dist/licenses.txt --overwrite --ci",
    "build:watch": "rollup -c -w",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "validate": "sgnl-validate",
    "dev": "node --env-file=.env scripts/dev-runner.js"
  },
  "keywords": [
    "sgnl",
    "active-directory",
    "ad",
    "ldap",
    "move",
    "rename",
    "identity",
    "security"
  ],
  "author": "SGNL Engineering",
  "license": "MIT",
  "dependencies": {
    "@sgnl-actions/utils": "github:sgnl-actions/utils#v1.0.9",
    "ldapts": "^7.3.0"
  },
  "devDependencies": {
    "@sgnl-actions/eslint-config": "github:sgnl-actions/eslint-config#23c69696e28fbf34e7eadb12a56cda5f491c282a",
    "@sgnl-actions/rollup-config": "github:sgnl-actions/rollup-config#f94654e450f82042ad8268ac69d79e03889031ee",
    "@sgnl-actions/validate": "github:sgnl-actions/validate#1392b07e0c1563e729d68d2eec328ee8e03e0783",
    "@sgnl-actions/testing": "github:sgnl-actions/testing#v1.0.5",
    "eslint": "^10.0.0",
    "generate-license-file": "^4.1.1",
    "jest": "^30.0.5",
    "rollup": "^4.59.0"
  },
  "overrides": {
    "serialize-javascript": ">=7.0.5",
    "uuid": ">=11.1.1",
    "generate-license-file": {
      "minipass-fetch": "5.0.2"
    }
  }
}
