{
  "name": "@sgnl-actions/ad-move-user",
  "version": "1.0.0",
  "description": "Move a user to a new parent container/OU in Active Directory",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "rollup -c",
    "build:watch": "rollup -c -w",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "validate": "node scripts/validate-metadata.js",
    "dev": "node --env-file=../.env scripts/dev-runner.js"
  },
  "keywords": [
    "sgnl",
    "active-directory",
    "ad",
    "ldap",
    "move",
    "rename",
    "identity",
    "security"
  ],
  "author": "SGNL Engineering",
  "license": "MIT",
  "dependencies": {
    "@sgnl-actions/utils": "github:sgnl-actions/utils#v1.0.5",
    "ldapts": "^7.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@rollup/plugin-commonjs": "^28.0.1",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "eslint": "^9.17.0",
    "jest": "^30.0.5",
    "js-yaml": "^4.1.0",
    "rollup": "^4.28.1"
  }
}
